# Copy to /etc/peerlink/env and set your Linode public IPv4.
LINODE_IP=172.104.206.154
API_PORT=8080
# UI port: 80 = open http://LINODE_IP/ in browser; 3000 = http://LINODE_IP:3000/
CLIENT_PORT=80
PUBLIC_CLIENT_PORT=80

# Baked into the UI at build time (browser calls API on this URL)
NEXT_PUBLIC_API_BASE_URL=http://172.104.206.154:8080
